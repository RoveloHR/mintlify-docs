{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Rovelo Docs",
  "colors": {
    "primary": "#1E4588",
    "light": "#4167a9",
    "dark": "#133060"
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "tabs": [
          {
            "tab": "Documents",
            "groups": [
              {
                "group": "Overview",
                "pages": [
                  "index",
                  "onboarding",
                  "platform-guide",
                  "features"
                ]
              }
            ]
          },
          {
            "tab": "API reference",
            "groups": [
              {
                "group": "API documentation",
                "pages": [
                  "api-reference/introduction"
                ]
              },
              {
                "group": "Endpoint examples",
                "pages": [
                  "api-reference/endpoint/get",
                  "api-reference/endpoint/create",
                  "api-reference/endpoint/delete",
                  "api-reference/endpoint/webhook"
                ]
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Changelog",
          "icon": "bell-ringing",
          "color": {
            "light": "#1E4588",
            "dark": "#1E4588"
          },
          "href": "https://rovelo.app/changelog"
        },
        {
          "anchor": "Discord Server",
          "icon": "brand-discord",
          "color": {
            "light": "#1E4588",
            "dark": "#1E4588"
          },
          "href": "https://discord.gg/y3kVrcwC7K"
        }
      ]
    }
  },
  "logo": "/logo/light.svg",
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://discord.gg/y3kVrcwC7K"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.rovelo.app"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  },
  "fonts": {
    "family": "Inter",
    "weight": 500,
    "format": "woff"
  },
  "icons": {
    "library": "tabler"
  },
  "description": "Everything you need to start using Rovelo",
  "styling": {
    "latex": false
  },
  "metadata": {
    "timestamp": false
  },
  "seo": {
    "indexing": "all"
  },
  "search": {
    "prompt": "Search or ask..."
  }
}
